# Скопируй в .env и заполни свои значения

# Telegram Bot Token - получи от @BotFather
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Пароль для доступа к WG-Easy Web UI
WG_PASSWORD=YOUR_WG_PASSWORD_HERE

# URL базовой API WG-Easy (по умолчанию http://127.0.0.1:51821/api)
WG_API_BASE=http://127.0.0.1:51821/api

# Максимум конфигов на одного пользователя (если не указан в unlimited_users.txt)
MAX_CONFIGS_PER_USER=4
